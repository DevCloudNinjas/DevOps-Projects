# Copy to terraform.tfvars and replace values for your own demo account.
# Keep private keys, live public IPs, and terraform.tfvars out of git.

aws_region = "us-east-1"

instance_type       = "t3.micro"
instance_ami        = "ami-0cd59ecaf368e5ccf"
instance_vpc_id     = "vpc-xxxxxxxxxxxxxxxxx"
instance_subnet_id  = "subnet-xxxxxxxxxxxxxxxxx"
instance_keyName    = "project-47-demo-key"
private_key_path    = "/absolute/path/outside/repo/project-47-demo-key.pem"
instance_publicip   = true
aws_availability_zone = "us-east-1b"

instance_secgroupname = "project-47-django-demo"

# For portfolio demos, restrict SSH and app ports to your public IP.
