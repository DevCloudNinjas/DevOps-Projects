# Local development template. Copy to .env and keep real values out of git.

SERVER=http://localhost:8585
PORT=8585
DEBUG=True
SECRET_KEY=replace-with-a-long-random-local-only-value
DJANGO_SECRET_KEY=replace-with-a-long-random-local-only-value
DJANGO_CREATE_SUPERUSER=false
DJANGO_SUPERUSER_PASSWORD=replace-only-if-DJANGO_CREATE_SUPERUSER-true
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_USERNAME=admin
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
CORS_ORIGIN_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOW_CREDENTIALS=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

POSTGRES_NAME=app
POSTGRES_USER=app_user
POSTGRES_PASSWORD=replace-with-local-db-password
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
BACKEND_DOMAIN=http://127.0.0.1:8585/
PAYMENT_SUCCESS_URL=http://127.0.0.1:8585/api/v1/products/success/
PAYMENT_CANCEL_URL=http://127.0.0.1:8585/api/v1/products/cancel/
STRIPE_WEBHOOK_SECRET=whsec_replace_me

EMAIL_USE_TLS=True
EMAIL_HOST=smtp.example.com
EMAIL_HOST_USER=notify@example.com
EMAIL_HOST_PASSWORD=replace-with-smtp-app-password
EMAIL_PORT=587
